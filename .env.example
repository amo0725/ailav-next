# ── AILAV Admin ──────────────────────────────────────────
# Generate all three via: npm run admin:init
ADMIN_PASSWORD_HASH=
ADMIN_TOTP_SECRET=
ADMIN_SESSION_SECRET=

# ── Vercel Blob ──────────────────────────────────────────
# Vercel Dashboard → Storage → Blob → Connect → copy the R/W token
BLOB_READ_WRITE_TOKEN=

# 開發/測試時設為 true，內容與圖片改寫到本機 .data/ 與 public/uploads/，不消耗 production blob 額度
# USE_LOCAL_BLOB=true

# ── Upstash Redis (optional, for login rate limiting) ─────
# Vercel Dashboard → Storage → Upstash → Connect → copy REST URL + token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
